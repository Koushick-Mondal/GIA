                <div class="relative">
                    <button id="notificationBtn" class="relative"><i class="far fa-bell text-xl text-gray-300 hover:text-white"></i><span id="notifCount" class="absolute -top-1 -right-1 h-4 w-4 bg-red-500 rounded-full text-[10px] flex items-center justify-center">3</span></button>
                    <div id="notificationDropdown" class="absolute right-0 mt-2 w-72 glass-card rounded-xl p-2 hidden z-30">

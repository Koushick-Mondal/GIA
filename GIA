</div>

<!-- TOAST -->
<div id="toast" class="fixed bottom-6 right-6 z-50 hidden glass-card px-5 py-3 rounded-xl text-sm shadow-2xl border-l-4 border-blue-500 max-w-sm"></div>

<script>
    (function(){
        "use strict";

        // ---------- ADVANCED AI ENGINEER STATE ----------
        let currentRole = null; 
        let currentPage = 'dashboard';
        let sidebarCollapsed = false;
        let darkMode = true;
        const mockUser = { 
            beneficiary: { name: 'Ramesh Kumar', id: 'BEN789', category: 'SC', income: 28000, village: 'Dharampur', aadhar: '****1234', blockchainHash: '0x7a9f...3d2e', aiProfile: { education: '10th', skills: ['farming'], dependents: 3 } },
            admin: { name: 'Anjali Sharma', id: 'ADM42', dept: 'Welfare' }
        };

        // Data stores
        let applications = [
            { id: 'APP101', scheme: 'PM-AJAY Hostel', status: 'Under Review', submitted: '2026-04-10', score: 82, steps: ['Submitted', 'Under Review'], aiNotes: 'High eligibility, recommended for fast-track', factors: { income: 0.8, category: 0.9, location: 0.7 } },
            { id: 'APP102', scheme: 'Skill Development', status: 'Approved', submitted: '2026-03-22', score: 91, steps: ['Submitted', 'Under Review', 'Approved'] }
        ];
        let beneficiaries = [
            { id: 'B001', name: 'Ramesh Kumar', village: 'Dharampur', income: 28000, status: 'Approved', risk: 'low', aadhar: '****1234', fraudScore: 12, aiTags: ['reliable'] },
            { id: 'B002', name: 'Suman Devi', village: 'Belgachi', income: 18000, status: 'Pending', risk: 'medium', fraudScore: 45 },
            { id: 'B003', name: 'Vikram Singh', village: 'Dharampur', income: 32000, status: 'Rejected', risk: 'high', duplicate: true, fraudScore: 88 },
            { id: 'B004', name: 'Geeta Bai', village: 'Ramnagar', income: 22000, status: 'Approved', risk: 'low', fraudScore: 8 },
            { id: 'B005', name: 'Mohan Lal', village: 'Belgachi', income: 45000, status: 'Pending', risk: 'high', anomaly: 'Income exceeds limit', fraudScore: 72 }
        ];
        let fundData = { allocated: 5200000, used: 4180000, predictions: { nextMonth: 4500000 } };
        let notifications = [
            { id: 1, text: 'AI Co-pilot: Your eligibility score increased to 82', read: false, time: '5m ago' },
            { id: 2, text: 'New scheme: PM-AJAY 2.0 launched', read: false, time: '1h ago' },
            { id: 3, text: 'Document verification complete (AI OCR)', read: false, time: '2h ago' }
        ];

        // Multi-agent simulation
        function updateAISuggestion() {
            const sug = document.getElementById('aiSuggestion');
            if (currentRole === 'beneficiary') {
                sug.textContent = `🔍 AI: Your eligibility score 82. Recommended: Apply for PM-AJAY Hostel.`;
            } else {
                sug.textContent = `📊 AI: 23 pending approvals. Fraud risk low.`;
            }
        }

        // WebSocket simulation
        let wsInterval;
        function startMockWebSocket() {
            if (wsInterval) clearInterval(wsInterval);
            wsInterval = setInterval(() => {
                if (currentRole === 'admin' && Math.random() > 0.7) {
                    const pending = beneficiaries.filter(b => b.status === 'Pending');
                    if (pending.length) {
                        const b = pending[Math.floor(Math.random() * pending.length)];
                        b.status = 'Approved';
                        addNotification(`AI auto-approved ${b.name} (confidence 94%)`, 'system');
                        if (currentPage === 'beneficiaries' || currentPage === 'dashboard') renderContent();
                    }
                }
                if (Math.random() > 0.8) {
                    addNotification('AI Agent: New policy impact analysis ready', 'info');
                }
                updateAISuggestion();
            }, 12000);
        }

        function addNotification(text, type = 'info') {
            notifications.unshift({ id: Date.now(), text, read: false, time: 'just now' });
            updateNotifBadge();
        }
        function updateNotifBadge() {
            const unread = notifications.filter(n => !n.read).length;
            document.getElementById('notifCount').textContent = unread;
        }
        function renderNotificationList() {
            const list = document.getElementById('notificationList');
            list.innerHTML = notifications.slice(0,6).map(n => `<div class="p-2 hover:bg-white/5 rounded cursor-pointer flex justify-between"><span>${n.text}</span><span class="text-gray-500">${n.time}</span></div>`).join('') || '<p class="text-gray-400 p-2">No notifications</p>';
        }

        // DOM
        const loginScreen = document.getElementById('loginScreen');
        const appContainer = document.getElementById('appContainer');
        const sidebarMenu = document.getElementById('sidebarMenu');
        const pageTitle = document.getElementById('pageTitle');
        const contentArea = document.getElementById('contentArea');
        const sidebarUserRole = document.getElementById('sidebarUserRole');
        const sidebarUserName = document.getElementById('sidebarUserName');
        const toastEl = document.getElementById('toast');

        function showToast(msg, type = 'info') {
            toastEl.textContent = msg;
            toastEl.className = 'fixed bottom-6 right-6 z-50 glass-card px-5 py-3 rounded-xl text-sm shadow-2xl border-l-4 max-w-sm ';
            toastEl.classList.add(type === 'success' ? 'border-emerald-500' : (type==='error'?'border-red-500':'border-blue-500'));
            toastEl.classList.remove('hidden');
            setTimeout(() => toastEl.classList.add('hidden'), 3200);
        }

        function toggleTheme() {
            darkMode = !darkMode;
            document.body.classList.toggle('light-mode', !darkMode);
            const icons = document.querySelectorAll('#themeToggle i, #toggleThemeLogin i');
            icons.forEach(icon => icon.className = darkMode ? 'far fa-moon' : 'far fa-sun');
            localStorage.setItem('theme', darkMode?'dark':'light');
        }

        // ---------- SIDEBAR & NAVIGATION ----------
        function renderSidebar() {
            if (!currentRole) return;
            const isBen = currentRole === 'beneficiary';
            const menuItems = isBen ? [
                { icon: 'fa-chart-pie', label: 'Dashboard', page: 'dashboard' },
                { icon: 'fa-file-signature', label: 'Apply Scheme', page: 'apply' },
                { icon: 'fa-timeline', label: 'Track', page: 'track' },
                { icon: 'fa-briefcase', label: 'Jobs', page: 'jobs' },
                { icon: 'fa-newspaper', label: 'News', page: 'news' },
                { icon: 'fa-robot', label: 'AI Assistant', page: 'chat' },
            ] : [
                { icon: 'fa-gauge-high', label: 'Dashboard', page: 'dashboard' },
                { icon: 'fa-users', label: 'Beneficiaries', page: 'beneficiaries' },
                { icon: 'fa-coins', label: 'Fund Tracking', page: 'funds' },
                { icon: 'fa-shield-hal', label: 'Fraud Detection', page: 'fraud' },
                { icon: 'fa-chart-line', label: 'Analytics', page: 'analytics' },
                { icon: 'fa-map', label: 'Geo Map', page: 'map' },
            ];
            sidebarMenu.innerHTML = menuItems.map(item => `
                <div class="sidebar-icon flex items-center gap-3 px-4 py-3 rounded-xl mb-1.5 cursor-pointer transition-all ${currentPage === item.page ? 'bg-blue-600/20 text-blue-200 border-l-2 border-blue-400 shadow-inner' : 'hover:bg-white/5 text-gray-300'}" data-page="${item.page}">
                    <i class="fas ${item.icon} w-5 text-lg"></i><span class="font-medium">${item.label}</span>
                </div>
            `).join('');
            document.querySelectorAll('[data-page]').forEach(el => el.addEventListener('click', (e) => navigateTo(el.dataset.page)));
            sidebarUserRole.textContent = isBen ? 'Beneficiary' : 'Administrator';
            sidebarUserName.textContent = isBen ? mockUser.beneficiary.name : mockUser.admin.name;
            updateAISuggestion();
        }

        function navigateTo(page) {
            currentPage = page;
            pageTitle.textContent = page.charAt(0).toUpperCase() + page.slice(1);
            renderSidebar();
            renderContent();
        }

        // ---------- CONTENT RENDERERS ----------
        function renderContent() {
            if (currentRole === 'beneficiary') renderBeneficiaryContent();
            else renderAdminContent();
        }

        // ---------- BENEFICIARY (AI ENGINEER GRADE) ----------
        function renderBeneficiaryContent() {
            let html = '';
            const score = 82; 
            if (currentPage === 'dashboard') {
                html = `
                    <div class="grid lg:grid-cols-3 gap-6">
                        <div class="lg:col-span-2 space-y-6">
                            <div class="glass-card p-6 rounded-2xl hover-lift ai-glow">
                                <div class="flex justify-between"><h3 class="text-xl font-semibold flex items-center gap-2"><i class="fas fa-brain text-blue-400"></i>AI Eligibility Score</h3><span class="bg-blue-500/20 px-3 py-1 rounded-full text-xs">Explainable AI</span></div>
                                <div class="flex items-end gap-4 mt-3"><span class="text-6xl font-bold text-blue-300">${score}</span><span class="text-gray-400 mb-1">/100 · Eligible</span></div>
                                <div class="mt-4 grid grid-cols-3 gap-2 text-xs">
                                    <div><span>Income factor</span><div class="w-full bg-gray-700 h-1.5 rounded"><div class="bg-blue-400 h-1.5 rounded" style="width:80%"></div></div></div>
                                    <div><span>Category</span><div class="w-full bg-gray-700 h-1.5 rounded"><div class="bg-blue-400 h-1.5 rounded" style="width:90%"></div></div></div>
                                    <div><span>Location</span><div class="w-full bg-gray-700 h-1.5 rounded"><div class="bg-blue-400 h-1.5 rounded" style="width:70%"></div></div></div>
                                </div>
                                <p class="text-xs text-blue-300 mt-3"><i class="fas fa-robot mr-1"></i>Reasoning: Income <30k, SC category, rural area → high alignment.</p>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="glass-card p-5 rounded-xl hover-lift"><i class="fas fa-clock text-blue-300 mb-2 text-2xl"></i><p class="text-3xl font-bold">${applications.filter(a=>a.status!=='Approved').length}</p><p class="text-gray-400 text-sm">Active apps</p></div>
                                <div class="glass-card p-5 rounded-xl hover-lift"><i class="fas fa-check-circle text-emerald-300 mb-2 text-2xl"></i><p class="text-3xl font-bold">${applications.filter(a=>a.status==='Approved').length}</p><p class="text-gray-400 text-sm">Approved</p></div>
                            </div>
                        </div>
                        <div class="glass-card p-5 rounded-2xl">
                            <h4 class="font-medium mb-4"><i class="fas fa-magic text-purple-300"></i> AI Recommendations</h4>
                            <div class="space-y-3">${['Data entry operator (94% match)','Web dev internship (89%)','Electrician training (82%)'].map(r=>`<div class="bg-white/5 p-3 rounded-lg border border-white/5 hover:bg-white/10 transition"><i class="fas fa-briefcase mr-2"></i>${r}</div>`).join('')}</div>
                            <div class="mt-4 p-3 bg-indigo-900/20 rounded-lg"><i class="fas fa-shield-alt text-indigo-300"></i> Blockchain anchor: ${mockUser.beneficiary.blockchainHash}</div>
                        </div>
                    </div>
                `;
            } else if (currentPage === 'apply') {
                html = renderMultiStepForm();
            } else if (currentPage === 'track') {
                html = `<div class="max-w-3xl glass-card p-6 rounded-2xl"><h3 class="text-xl mb-4 flex items-center gap-2"><i class="fas fa-history"></i>Application Timeline</h3>${renderTimeline()}</div>`;
            } else if (currentPage === 'jobs') {
                html = renderJobsPage();
            } else if (currentPage === 'news') {
                html = renderNewsPage();
            } else if (currentPage === 'chat') {
                html = renderAIChat();
            }
            contentArea.innerHTML = html;
            if (currentPage === 'apply') initFormSteps();
            if (currentPage === 'chat') initChat();
            if (currentPage === 'jobs') initJobFilters();
        }

        function renderMultiStepForm() {
            return `<div class="max-w-4xl glass-card p-6 rounded-2xl"><div class="flex justify-between mb-8" id="progressSteps">${stepsHTML()}</div><div id="stepContent">${step1HTML()}</div><div class="flex justify-between mt-8"><button id="prevStep" class="px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 disabled:opacity-40 transition" disabled>Previous</button><button id="nextStep" class="px-6 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl hover:scale-105 transition shadow-lg">Next</button></div><p class="text-right text-xs text-gray-400 mt-2"><i class="far fa-save"></i> AI auto-save enabled · Smart validation</p></div>`;
        }
        function stepsHTML(){ return ['Personal','Socio-economic','Documents','Review'].map((s,i)=>`<div class="progress-step flex items-center" data-step="${i}"><div class="step-circle w-8 h-8 rounded-full border-2 border-white/30 flex items-center justify-center text-sm font-medium">${i+1}</div><span class="ml-3 text-sm font-medium">${s}</span></div>`).join(''); }
        function step1HTML(){ return `<div class="space-y-4"><label class="block text-sm">Full name <input id="fullName" value="${mockUser.beneficiary.name}" class="w-full bg-black/30 border border-white/10 rounded-xl p-3 mt-1"></label><label>DOB <input type="date" value="1998-05-12" class="w-full bg-black/30 border border-white/10 rounded-xl p-3 mt-1"></label><label>Gender <select class="w-full bg-black/30 border border-white/10 rounded-xl p-3"><option>Male</option></select></label></div>`; }
        function initFormSteps(){
            let step = 0; const steps = document.querySelectorAll('.progress-step');
            const prev=document.getElementById('prevStep'), next=document.getElementById('nextStep');
            const updateStepUI = () => {
                steps.forEach((s,i)=>{ s.classList.toggle('active', i===step); s.classList.toggle('completed', i<step); });
                prev.disabled = step===0;
                next.textContent = step===3?'Submit':'Next';
                if(step===0) document.getElementById('stepContent').innerHTML = step1HTML();
                else if(step===1) document.getElementById('stepContent').innerHTML = `<div class="space-y-4"><label>Annual Income <input value="28000" class="w-full bg-black/30 border border-white/10 rounded-xl p-3"></label><label>Category <select class="w-full bg-black/30 p-3 rounded-xl"><option>SC</option></select></label></div>`;
                else if(step===2) document.getElementById('stepContent').innerHTML = `<div class="border-2 border-dashed border-white/20 rounded-xl p-8 text-center"><i class="fas fa-cloud-upload-alt text-3xl mb-2"></i><p>Upload Aadhar, Income certificate</p><button class="mt-3 bg-blue-600/30 px-4 py-2 rounded-lg" id="simulateOCR">Simulate AI OCR</button><p class="text-xs mt-2 text-green-300 hidden" id="ocrResult">✓ Documents verified (AI confidence 98%)</p></div>`;
                else document.getElementById('stepContent').innerHTML = `<div class="p-4 bg-emerald-900/20 rounded-xl">Review: ${mockUser.beneficiary.name}, SC, Income ₹28k. AI eligibility: 82. Ready to submit.</div>`;
                if(step===2) document.getElementById('simulateOCR')?.addEventListener('click', ()=> { document.getElementById('ocrResult').classList.remove('hidden'); showToast('AI OCR verification passed', 'success'); });
            };
            next.onclick = ()=>{
                if(step<3) { step++; updateStepUI(); }
                else { 
                    applications.push({ id:'APP'+(applications.length+100), scheme:'New Application', status:'Submitted', submitted: new Date().toISOString().slice(0,10), score:82, steps:['Submitted'] });
                    showToast('Application submitted! Blockchain TX pending...', 'success'); navigateTo('track'); 
                }
            };
            prev.onclick = ()=>{ if(step>0){ step--; updateStepUI(); } };
            updateStepUI();
        }

        function renderTimeline(){
            return applications.map(a=>`<div class="border-l-2 ${a.status==='Approved'?'border-emerald-500':'border-blue-500'} pl-5 py-4"><div class="flex justify-between"><span class="font-medium text-lg">${a.scheme}</span><span class="text-xs bg-white/10 px-2 py-1 rounded">${a.status}</span></div><div class="flex text-sm text-gray-400 mt-2 gap-4">${a.steps.map(s=>`<span><i class="fas fa-circle text-[6px] mr-1"></i>${s}</span>`).join('')}</div>${a.aiNotes?`<p class="text-xs text-blue-300 mt-1"><i class="fas fa-robot mr-1"></i>${a.aiNotes}</p>`:''}</div>`).join('');
        }

        function renderJobsPage(){
            return `<div class="space-y-5"><div class="flex gap-3"><input id="jobSearch" placeholder="Search jobs..." class="bg-black/20 border border-white/10 rounded-xl p-3 flex-1"><button class="bg-blue-600 px-5 rounded-xl"><i class="fas fa-search"></i></button></div><div id="jobList" class="grid md:grid-cols-2 gap-4">${getJobCards()}</div></div>`;
        }
        function getJobCards(filter=''){
            const jobs = ['Govt Clerk - Dharampur (AI match 94%)','IT Intern - Skill India (89%)','Field Surveyor (82%)'];
            return jobs.filter(j=>!filter||j.toLowerCase().includes(filter.toLowerCase())).map(j=>`<div class="glass-card p-5 rounded-xl hover-lift"><div class="flex justify-between"><h4 class="font-medium">${j.split('(')[0]}</h4><span class="bg-blue-500/20 text-blue-200 text-xs px-2 py-1 rounded-full">${j.match(/\(.*\)/)[0]}</span></div><p class="text-sm text-gray-400 mt-2">Stipend ₹8k-12k · Apply by May 10</p><button class="mt-3 text-sm bg-white/5 px-4 py-1.5 rounded-lg hover:bg-white/10"><i class="far fa-bookmark mr-1"></i>Save</button></div>`).join('');
        }
        function initJobFilters(){ const input=document.getElementById('jobSearch'); if(input) input.addEventListener('input', e=> document.getElementById('jobList').innerHTML = getJobCards(e.target.value)); }
        function renderNewsPage(){ return `<div class="glass-card p-5"><h3>📰 AI-curated News</h3><div class="space-y-3">${[{cat:'Gov',title:'Cabinet approves ₹2000Cr for PM-AJAY'},{cat:'Tech',title:'Digital literacy mission launched'}].map(n=>`<div class="border-b border-white/5 pb-3"><span class="text-xs text-blue-300">${n.cat}</span><p>${n.title}</p></div>`).join('')}</div></div>`; }
        function renderAIChat(){
            return `<div class="flex h-[75vh] glass-card rounded-2xl overflow-hidden"><div class="w-72 border-r border-white/5 p-3"><h4 class="mb-3 text-sm"><i class="far fa-comments"></i> History</h4><div class="text-xs space-y-1"><div class="p-2 rounded hover:bg-white/5 cursor-pointer">Eligibility check</div></div></div><div class="flex-1 flex flex-col"><div class="flex-1 overflow-y-auto p-4 space-y-3" id="chatMessages"><div class="flex gap-3"><i class="fas fa-robot text-blue-300"></i><div class="bg-white/5 p-4 rounded-2xl max-w-[80%]">Hello! I'm your AI assistant. Ask about schemes, eligibility, or try voice input.</div></div></div><div class="p-4 border-t flex gap-2"><button id="voiceInputBtn" class="bg-white/10 px-4 rounded-xl"><i class="fas fa-microphone"></i></button><input id="chatInput" placeholder="Ask me anything..." class="flex-1 bg-black/30 rounded-xl p-3"><button id="sendChat" class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 rounded-xl"><i class="fas fa-paper-plane"></i></button></div></div></div>`;
        }
        function initChat(){
            const input=document.getElementById('chatInput'), btn=document.getElementById('sendChat'), container=document.getElementById('chatMessages');
            function addMessage(text, isUser=false){
                const div=document.createElement('div'); div.className=`flex gap-3 ${isUser?'justify-end':''}`;
                div.innerHTML= isUser? `<div class="bg-blue-600/30 p-4 rounded-2xl max-w-[75%]">${text}</div><i class="fas fa-user-circle"></i>` : `<i class="fas fa-robot text-blue-300"></i><div class="bg-white/5 p-4 rounded-2xl max-w-[75%]">${text}<span class="typing-dot">●</span></div>`;
                container.appendChild(div); container.scrollTop=container.scrollHeight;
            }
            btn.onclick=()=>{ const val=input.value.trim(); if(!val)return; addMessage(val,true); input.value=''; 
                setTimeout(()=>{ addMessage(`Based on your profile (income ₹28k, SC), eligibility score is 82. You qualify for PM-AJAY hostel and skill vouchers.`); },700);
            };
            document.getElementById('voiceInputBtn').addEventListener('click', ()=> { showToast('Voice: "Am I eligible?"', 'info'); input.value='Am I eligible?'; });
        }

        // ---------- ADMIN (AI ENGINEER GRADE with network graph) ----------
        function renderAdminContent() {
            let html = '';
            if (currentPage === 'dashboard') {
                html = `<div class="space-y-6"><div class="grid grid-cols-4 gap-5">${[{label:'Total beneficiaries',val:beneficiaries.length,icon:'users'},{label:'Pending',val:beneficiaries.filter(b=>b.status==='Pending').length,icon:'clock',color:'yellow'},{label:'Approved',val:beneficiaries.filter(b=>b.status==='Approved').length,icon:'check-circle',color:'emerald'},{label:'Funds used',val:'₹'+(fundData.used/100000).toFixed(1)+'L',icon:'coins'}].map(c=>`<div class="glass-card p-5 rounded-xl"><i class="fas fa-${c.icon} text-2xl text-${c.color||'blue'}-300 mb-2"></i><p class="text-3xl font-bold">${c.val}</p><p class="text-gray-400 text-sm">${c.label}</p></div>`).join('')}</div>
                <div class="grid grid-cols-2 gap-6"><div class="glass-card p-5"><canvas id="regionChart" height="200"></canvas></div><div class="glass-card p-5"><canvas id="trendChart" height="200"></canvas></div></div>
                <div class="glass-card p-5"><h4>📈 AI Forecast: Next month fund utilization</h4><div class="h-20 flex items-end"><div class="w-16 bg-blue-500/40 h-12">₹41.8L</div><div class="w-16 bg-indigo-500/40 h-16 ml-2">₹45L (predicted)</div></div></div></div>`;
                setTimeout(()=>{ renderCharts(); },60);
            } else if (currentPage === 'beneficiaries') {
                html = `<div class="glass-card p-5"><div class="flex justify-between mb-4"><h3>Beneficiary Management</h3><div class="flex gap-2"><input id="beneficiaryFilter" placeholder="Filter..." class="bg-black/20 border border-white/10 rounded-lg px-3 py-2"><button id="exportBeneficiaries" class="bg-indigo-600/30 px-3 py-1 rounded-lg text-sm"><i class="fas fa-download"></i>Export</button></div></div><div id="beneficiaryTableContainer">${beneficiaryTable()}</div></div>`;
                setTimeout(()=> { attachBeneficiaryActions(); document.getElementById('beneficiaryFilter').addEventListener('input', e=> document.getElementById('beneficiaryTableContainer').innerHTML = beneficiaryTable(e.target.value)); },50);
            } else if (currentPage === 'funds') {
                html = `<div class="glass-card p-6"><h3>💰 Fund Allocation vs Usage</h3><div class="flex items-end gap-8 h-40"><div class="w-32 bg-blue-500/40 h-28 rounded-t-lg">₹52L</div><div class="w-32 bg-emerald-500/40 h-20 rounded-t-lg">₹41.8L</div></div><button id="updateFundsBtn" class="mt-4 bg-blue-600/30 px-4 py-2 rounded-lg">Simulate Disbursement</button></div>`;
                setTimeout(()=> document.getElementById('updateFundsBtn').addEventListener('click', ()=>{ fundData.used = Math.min(fundData.allocated, fundData.used+200000); renderContent(); }),50);
            } else if (currentPage === 'fraud') {
                html = `<div class="glass-card p-5"><h3>🚨 Fraud Network Graph</h3><div class="flex gap-6"><div class="w-1/2"><canvas id="networkCanvas" width="400" height="300" class="network-graph"></canvas></div><div class="w-1/2 space-y-2">${fraudAlerts()}</div></div></div>`;
                setTimeout(()=> drawNetworkGraph(), 50);
            } else if (currentPage === 'analytics') {
                html = `<div class="glass-card p-5"><h3>Predictive Analytics</h3><canvas id="analyticsChart" height="250"></canvas></div>`; setTimeout(()=>{ new Chart(document.getElementById('analyticsChart'),{type:'bar',data:{labels:['Dharampur','Belgachi','Ramnagar'],datasets:[{label:'Applications',data:[340,210,190]}]}}); },60);
            } else if (currentPage === 'map') {
                html = `<div class="glass-card p-5"><h3>🌍 AI Heatmap</h3><div class="h-96 rounded-xl relative overflow-hidden"><canvas id="heatmapCanvas" class="absolute inset-0 w-full h-full"></canvas><div class="absolute inset-0 flex items-center justify-center text-white"><span class="bg-black/40 px-4 py-2 rounded-full">Live heatmap · Dharampur high density</span></div></div></div>`;
                setTimeout(()=> drawHeatmap(), 50);
            }
            contentArea.innerHTML = html;
        }

        function beneficiaryTable(filter=''){
            const filtered = beneficiaries.filter(b=> !filter || b.name.toLowerCase().includes(filter.toLowerCase()) || b.village.toLowerCase().includes(filter.toLowerCase()));
            return `<table class="w-full text-sm"><thead><tr><th>Name</th><th>Village</th><th>Income</th><th>Status</th><th>Fraud Score</th><th>Actions</th></tr></thead><tbody>${filtered.map(b=>`<tr><td>${b.name}</td><td>${b.village}</td><td>₹${b.income}</td><td><span class="px-2 py-1 rounded text-xs ${b.status==='Approved'?'bg-emerald-500/20':(b.status==='Pending'?'bg-yellow-500/20':'bg-red-500/20')}">${b.status}</span></td><td>${b.fraudScore}</td><td><button data-id="${b.id}" data-action="approve" class="text-blue-400 mr-3"><i class="fas fa-check"></i></button><button data-id="${b.id}" data-action="reject" class="text-red-400"><i class="fas fa-times"></i></button></td></tr>`).join('')}</tbody></table>`;
        }
        function attachBeneficiaryActions(){
            document.querySelectorAll('[data-action]').forEach(btn=>{ btn.addEventListener('click', (e)=>{
                const id = btn.dataset.id; const action = btn.dataset.action;
                const beneficiary = beneficiaries.find(b=>b.id===id);
                if(beneficiary) { beneficiary.status = action==='approve'?'Approved':'Rejected'; showToast(`${beneficiary.name} ${action}d`, 'success'); renderContent(); }
            })});
        }
        function fraudAlerts(){
            return beneficiaries.filter(b=>b.fraudScore>60).map(b=>`<div class="fraud-alert-item p-3 rounded-lg mb-2 flex justify-between"><div><i class="fas fa-exclamation-triangle text-red-400"></i> ${b.name} (score ${b.fraudScore})</div><button data-resolve="${b.id}" class="text-xs bg-red-500/20 px-2 py-1 rounded">Resolve</button></div>`).join('');
        }
        function renderCharts(){
            new Chart(document.getElementById('regionChart'),{type:'doughnut',data:{labels:['Dharampur','Belgachi','Ramnagar'],datasets:[{data:[540,340,290]}]}});
            new Chart(document.getElementById('trendChart'),{type:'line',data:{labels:['Jan','Feb','Mar','Apr'],datasets:[{label:'Apps',data:[120,190,240,310]}]}});
        }
        function drawNetworkGraph(){
            const canvas = document.getElementById('networkCanvas');
            if(!canvas) return;
            const ctx = canvas.getContext('2d');
            const nodes = [{x:100,y:100},{x:200,y:80},{x:150,y:180},{x:250,y:150}];
            ctx.strokeStyle = '#ef4444'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.moveTo(100,100); ctx.lineTo(200,80); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(100,100); ctx.lineTo(150,180); ctx.stroke();
            nodes.forEach(n=>{ ctx.fillStyle='#3b82f6'; ctx.beginPath(); ctx.arc(n.x,n.y,8,0,2*Math.PI); ctx.fill(); });
        }
        function drawHeatmap(){
            const canvas=document.getElementById('heatmapCanvas'); if(!canvas)return;
            const ctx=canvas.getContext('2d'); canvas.width=canvas.offsetWidth; canvas.height=canvas.offsetHeight;
            const grad=ctx.createRadialGradient(200,150,10,200,150,200);
            grad.addColorStop(0,'rgba(255,0,0,0.7)'); grad.addColorStop(1,'rgba(0,255,0,0.1)');
            ctx.fillStyle=grad; ctx.fillRect(0,0,canvas.width,canvas.height);
        }

        // ---------- INIT ----------
        function setRole(role){
            currentRole = role;
            loginScreen.classList.add('hidden');
            appContainer.classList.remove('hidden');
            renderSidebar();
            navigateTo('dashboard');
            showToast(`Welcome, ${role==='beneficiary'?mockUser.beneficiary.name:mockUser.admin.name}`, 'success');
            startMockWebSocket();
            updateNotifBadge();
        }

        document.getElementById('loginAsBeneficiary').addEventListener('click', ()=> setRole('beneficiary'));
        document.getElementById('loginAsAdmin').addEventListener('click', ()=> setRole('admin'));
        document.getElementById('sidebarToggle').addEventListener('click', ()=>{
            sidebarCollapsed = !sidebarCollapsed;
            document.getElementById('sidebar').style.width = sidebarCollapsed ? '90px' : '320px';
            document.querySelectorAll('#sidebarMenu span').forEach(s=> s.style.display = sidebarCollapsed?'none':'inline');
        });
        document.getElementById('themeToggle').addEventListener('click', toggleTheme);
        document.getElementById('toggleThemeLogin').addEventListener('click', toggleTheme);
        document.getElementById('notificationBtn').addEventListener('click', (e) => {
            e.stopPropagation();
            const dd = document.getElementById('notificationDropdown');
            dd.classList.toggle('hidden');
            renderNotificationList();
        });
        document.addEventListener('click', () => document.getElementById('notificationDropdown').classList.add('hidden'));
        document.addEventListener('click', (e) => {
            if(e.target.closest('[data-resolve]')) {
                const id = e.target.closest('[data-resolve]').dataset.resolve;
                const idx = beneficiaries.findIndex(b=>b.id===id);
                if(idx!==-1) { beneficiaries.splice(idx,1); showToast('Alert resolved', 'success'); renderContent(); }
            }
        });

        if(localStorage.getItem('theme')==='light') { darkMode=false; document.body.classList.add('light-mode'); document.querySelectorAll('#themeToggle i, #toggleThemeLogin i').forEach(i=>i.className='far fa-sun'); }
        updateNotifBadge();
    })();
</script>
</body>
</html>

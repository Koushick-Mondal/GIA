                </div>
                <div class="h-9 w-9 rounded-full bg-gradient-to-tr from-blue-400 to-indigo-600 border-2 border-white/20"></div>
            </div>
        </header>

        <div id="contentArea" class="flex-1 overflow-auto p-6 scroll-smooth animate-in">
            <!-- injected -->

                <h2 class="font-semibold text-xl" id="pageTitle">Dashboard</h2>
                <span class="ml-2 text-xs bg-indigo-900/40 text-indigo-200 px-2 py-1 rounded-full border border-indigo-500/30"><i class="fas fa-link mr-1"></i>ZK‑Proof verified</span>
            </div>
            <div class="flex items-center gap-5">
